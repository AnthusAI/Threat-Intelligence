{
  "name": "papyrus",
  "version": "1.0.0",
  "private": true,
  "description": "A Pretext-powered responsive newspaper layout lab.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "favicon:generate": "node scripts/favicon/generate-favicon.mjs",
    "content": "poetry run papyrus-content",
    "lint": "eslint .",
    "test:newsroom": "node scripts/test-newsroom-session.cjs",
    "test:newsroom-card-layout": "node scripts/test-newsroom-card-layout.cjs",
    "typecheck": "tsc --noEmit",
    "sandbox": "ampx sandbox",
    "seed:amplify": "ampx sandbox seed",
    "auth:refresh-jwt": "node scripts/refresh-jwt.cjs",
    "test:assignments": "node scripts/test-category-mappers.cjs",
    "test:categories": "node scripts/test-category-mappers.cjs",
    "test:doi-backfill": "node scripts/test-doi-backfill.cjs",
    "test:identifier-backfill": "node scripts/test-doi-backfill.cjs",
    "test:content-cli-live": "poetry run python -m unittest procedures.newsroom.tests.test_content_cli_live -v",
    "test:bdd": "cucumber-js",
    "test:bdd:headed": "PAPYRUS_HEADLESS=false cucumber-js"
  },
  "keywords": [
    "nextjs",
    "react",
    "pretext",
    "newspaper",
    "layout"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-amplify/adapter-nextjs": "^1.7.3",
    "@aws-sdk/client-cognito-identity-provider": "3.1045.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/client-ssm": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@chenglou/pretext": "^0.0.7",
    "aws-amplify": "^6.17.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "next": "^15.5.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yaml": "^2.9.0",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@aws-amplify/seed": "^1.1.2",
    "@cucumber/cucumber": "^12.8.3",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "jsonschema": "^1.4.1",
    "lucide-static": "^1.16.0",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3"
  }
}
