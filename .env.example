# Reader runtime. Papyrus reads Amplify GraphQL content by default.
# Fixture scenarios are selected with ?scenario=<id>, not an env toggle.
PAPYRUS_EDITION_SLUG=current
PAPYRUS_BASE_URL=http://localhost:3001

# Local Next.js (`npm run dev`) uses amplify_outputs.json for AppSync/Cognito.
# `npm run dev` runs scripts/ensure-sandbox-amplify-outputs.mjs first so that file
# targets the Ryan sandbox (nkqutx AppSync, pool us-east-1_WD8fuTRVk), not production.
# Optional override when your sandbox stack name differs:
# PAPYRUS_SANDBOX_AMPLIFY_STACK=amplify-papyrus-ryan-sandbox-adcd88a186
#
# Production debugging (~/Projects/Papyrus-production or npm run dev:production):
# Keep production amplify_outputs.json (64hviw AppSync, pool us-east-1_40Uot7WSv).
# PAPYRUS_USE_PRODUCTION_AMPLIFY=1
# PAPYRUS_AMPLIFY_TARGET=production

# Content authoring CLI. The JWT is a direct token validated by the AppSync
# Lambda authorizer; it is not obtained from a Papyrus Cognito login flow.
PAPYRUS_GRAPHQL_ENDPOINT=
PAPYRUS_GRAPHQL_JWT=
# Automation/cron: set PAPYRUS_JWT_SECRET in Cursor automation secrets so
# scripts/dispatch-immediate-ai-ml-academic-research.cjs can mint authoring JWTs.
# PAPYRUS_JWT_SECRET=
# Optional defaults for `poetry run papyrus auth refresh-jwt --write-env .env`
# PAPYRUS_JWT_SECRET_SSM_PARAM=/amplify/papyrus/ryan-sandbox-adcd88a186/PAPYRUS_JWT_SECRET
# PAPYRUS_JWT_TTL_SECONDS=43200
# Optional local preflight check for a required authoring claim.
# PAPYRUS_JWT_AUTHORING_CLAIM=groups
# PAPYRUS_JWT_AUTHORING_VALUE=editor

# Authoring JWT values enforced by the deployed Lambda authorizer.
# PAPYRUS_JWT_ISSUER=papyrus-cli
# PAPYRUS_JWT_AUDIENCE=papyrus-authoring
# PAPYRUS_JWT_REQUIRED_SCOPE=papyrus:write

# Use an AWS profile for Amplify sandbox, deploy, and seed commands.
# Example:
# AWS_PROFILE=default
# AWS_REGION=us-east-1

# Amplify backend feature gates (sandbox defaults off unless set explicitly).
# Production main-branch pipeline enables inbound email and storage backups automatically.
# PAPYRUS_ENABLE_INBOUND_EMAIL=true
# PAPYRUS_ENABLE_STORAGE_BACKUPS=true
# PAPYRUS_STORAGE_BACKUP_VAULT_NAME=papyrus-dbsyytcm9drqa-main-media-backup-vault
# PAPYRUS_CONSOLE_RESPONDER_ALLOW_LOCAL_BUILD=true

# Inbound SES submission intake (Amplify backend).
# PAPYRUS_INBOUND_EMAIL_DOMAIN=p.apyr.us
# PAPYRUS_INBOUND_EMAIL_LOCAL_PARTS=submissions,suggestions
# PAPYRUS_INBOUND_EMAIL_CORPUS_KEY=AI-ML-research
# PAPYRUS_INBOUND_FEEDBACK_EMAIL_ENABLED=true
# PAPYRUS_INBOUND_FEEDBACK_FROM_EMAIL=Papyrus Submissions <submissions@p.apyr.us>
# Public newsroom links in submission feedback emails (overrides .papyrus/config.yaml publicSite.baseUrl).
# PAPYRUS_PUBLIC_SITE_BASE_URL=https://p.apyr.us

# Reference web search (research harness, title/subtitle enrichment).
# Default provider is Tavily; set WEB_SEARCH_PROVIDER=openai to use OpenAI web search.
# WEB_SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=
#
# Tavily deep research assignments (research.tavily-deep):
#   poetry run papyrus assignments create-research --type research.tavily-deep --title "Topic" ...
#   poetry run papyrus assignments run-tavily-deep-research --assignment <id> --wait
# Optional: --tavily-model auto|mini|pro (default auto on assignment metadata)
# OPENAI_API_KEY=  # still required for LLM calls and when WEB_SEARCH_PROVIDER=openai
#
# Live Tavily integration test (optional):
#   TAVILY_LIVE_TEST=1 PYTHONPATH=src poetry run pytest procedures/newsroom/tests/test_web_search_providers.py -k live
#
# End-to-end dogfood on sandbox (requires JWT + Tavily key):
#   ./scripts/dogfood-tavily-research.sh "Your topic" "search query for Tavily"

# Optional seed editor identity for `npm run seed:amplify`.
# These are app-level credentials created inside Cognito by the seed script.
PAPYRUS_SEED_USERNAME=papyrus-seed-editor
PAPYRUS_SEED_PASSWORD=change-me
PAPYRUS_SEED_EMAIL=papyrus-seed-editor@example.com
